{
  "Svelte Script": {
    "prefix": "script",
    "body": ["<script lang=\"ts\">", "\t$0", "</script>"]
  },
  "Svelte Component": {
    "prefix": "sve",
    "body": [
      "<script lang=\"ts\">",
      "\t$0",
      "</script>",
      "",
      "<div>",
      "\t",
      "</div>",
      "",
      "<style>",
      "</style>"
    ]
  },
  "$state": {
    "prefix": "state",
    "body": ["let ${1:name} = $state(${2:value});"]
  },
  "$derived": {
    "prefix": "derived",
    "body": ["let ${1:name} = $derived(${2:expr});"]
  },
  "$effect": {
    "prefix": "effect",
    "body": ["$effect(() => {", "\t$0", "});"]
  },
  "$props": {
    "prefix": "props",
    "body": ["let { ${1:prop} } = $props();"]
  },
  "#if": {
    "prefix": "if",
    "body": ["{#if ${1:condition}}", "\t$0", "{/if}"]
  },
  "#if/#else": {
    "prefix": "ife",
    "body": ["{#if ${1:condition}}", "\t$2", "{:else}", "\t$0", "{/if}"]
  },
  "#each": {
    "prefix": "each",
    "body": ["{#each ${1:items} as ${2:item}}", "\t$0", "{/each}"]
  },
  "#await": {
    "prefix": "await",
    "body": [
      "{#await ${1:promise}}",
      "\t<p>Loading...</p>",
      "{:then ${2:data}}",
      "\t$0",
      "{:catch ${3:error}}",
      "\t<p>{${3:error}.message}</p>",
      "{/await}"
    ]
  },
  "#snippet": {
    "prefix": "snip",
    "body": ["{#snippet ${1:name}(${2:props})}", "\t$0", "{/snippet}"]
  },
  "@render": {
    "prefix": "render",
    "body": ["{@render ${1:snippet}()}"]
  }
}
